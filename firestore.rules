rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'role']) &&
             data.keys().size() <= 6 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL']);
    }
  }
}
